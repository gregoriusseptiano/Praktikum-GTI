{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build OpenGL",
      "type": "process",
      "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
      "args": [
        "${file}",
        "-IC:/msys64/mingw64/include",
        "-LC:/msys64/mingw64/lib",
        "-lfreeglut",
        "-lopengl32",
        "-lglu32",
        "-lgdi32",
        "-mwindows",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}